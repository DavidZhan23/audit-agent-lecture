# 复制为 deploy.env 后修改：
#   cp deploy/deploy.env.example deploy/deploy.env

# 服务器 SSH 登录（必填）
SERVER_HOST=211.159.166.109
SERVER_USER=root

# 可选：指定私钥路径，留空则使用 ssh-agent / 默认密钥
# SSH_KEY=~/.ssh/id_ed25519

# 远程部署目录（与 fitness 应用目录分开）
REMOTE_DIR=/var/www/audit-agent-courseware

# 对外端口（fitness 占用 80，课件使用 8080；由 PM2 直接监听）
APP_PORT=3001
NGINX_PORT=8080

# PM2 进程名
PM2_APP_NAME=audit-courseware
PM2_FACE_NAME=face-predict

# 是否部署并启动 ANN 人脸推理（第 ③ 章真实演示）
ENABLE_FACE_PREDICT=true
FACE_PREDICT_HOST=127.0.0.1
FACE_PREDICT_PORT=8765
# Node 同源代理目标（一般不用改）
FACE_PREDICT_URL=http://127.0.0.1:8765

# 首次部署时是否自动安装 Node 22 / PM2 / Python3
AUTO_SETUP=true
